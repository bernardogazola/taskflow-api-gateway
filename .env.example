# TaskFlow - ambiente local completo.
# Copie este arquivo para .env antes de usar docker compose.

MSSQL_SA_PASSWORD=Your_strong_Pass123

AZURE_SQL_JDBC_URL=jdbc:sqlserver://mssql:1433;databaseName=taskflow;encrypt=false;trustServerCertificate=true
AZURE_SQL_USER=sa
AZURE_SQL_PASSWORD=Your_strong_Pass123

MONGODB_CONNECTION_STRING=mongodb://mongo:27017
MONGODB_DATABASE=taskflow

SERVICEBUS_CONNECTION_STRING=Endpoint=sb://servicebus-emulator;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SAS_KEY_VALUE;UseDevelopmentEmulator=true;
SERVICEBUS_TOPIC=task-events
SERVICEBUS_SUBSCRIPTION=user-notifications

# Par de chaves RS256 usado em desenvolvimento local.
# Gere chaves descartáveis para dev:
# openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out privateKey.pem
# openssl rsa -pubout -in privateKey.pem -out publicKey.pem
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=